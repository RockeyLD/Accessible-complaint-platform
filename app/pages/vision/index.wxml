<view class="page vision-page theme-{{theme}} {{highContrast ? 'high-contrast' : ''}}" style="font-size: {{fontSize}}%;">
  <!-- 顶部工具栏 -->
  <view class="toolbar">
    <view class="tool">
      <text class="tool-label">字号</text>
      <picker mode="selector" range="{{fontSizeOptions}}" range-key="label" bindchange="onFontSizeChange">
        <view class="picker">{{currentFontSizeLabel}}</view>
      </picker>
    </view>
    <view class="tool">
      <button class="toggle-btn {{highContrast ? 'active' : ''}}" bindtap="onToggleContrast">
        {{highContrast ? "高对比" : "正常"}}
      </button>
    </view>
    <view class="tool">
      <button class="toggle-btn {{autoSpeak ? 'active' : ''}}" bindtap="onToggleAutoSpeak">
        {{autoSpeak ? "自动读" : "手动读"}}
      </button>
    </view>
  </view>

  <!-- 欢迎面板 -->
  <view class="welcome-panel" wx:if="{{showWelcome}}">
    <text class="welcome-title">👨‍🦯 视障友好 · AI倾诉助手</text>
    <text class="welcome-desc">我会用语音陪你聊天。点击下方麦克风按钮说话，或者输入文字，我会帮你整理成清晰的倾诉。</text>
    <button class="start-btn" bindtap="startChat">开始倾诉</button>
  </view>

  <!-- 对话区域 -->
  <scroll-view wx:else class="chat-container" scroll-y scroll-into-view="{{scrollToMessage}}" enhanced show-scrollbar>
    <!-- 语音输入大按钮 -->
    <view class="voice-section">
      <button 
        class="voice-btn {{isRecording ? 'recording' : ''}}" 
        bindtouchstart="startVoiceInput"
        bindtouchend="stopVoiceInput"
        bindlongpress="onVoiceLongPress"
        aria-label="按住说话，松开发送"
      >
        <text class="voice-icon">{{isRecording ? '🔴' : '🎤'}}</text>
        <text class="voice-text">{{isRecording ? '松开发送' : '按住说话'}}</text>
      </button>
      <text class="voice-hint">按住麦克风按钮说话，松开后自动发送</text>
    </view>

    <!-- 消息列表 - 简化显示，优化读屏 -->
    <view class="messages-wrap">
      <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="message {{item.role === 'user' ? 'user-message' : 'ai-message'}} {{item.isError ? 'error-message' : ''}}">
        <view class="message-header">
          <text class="sender-name">{{item.role === 'user' ? '你' : 'AI助手'}}</text>
          <text wx:if="{{item.role === 'assistant'}}" class="speak-btn" data-index="{{index}}" bindtap="speakMessage">🔊 朗读</text>
        </view>
        <view class="message-body">
          <text class="message-text" user-select>{{item.content}}</text>
        </view>
        <view wx:if="{{item.parsed && item.parsed.isComplete}}" class="complete-badge">信息已完整</view>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{isLoading}}" class="message ai-message loading">
        <view class="message-header">
          <text class="sender-name">AI助手</text>
        </view>
        <view class="message-body">
          <text class="loading-text">正在思考...</text>
        </view>
      </view>
    </view>

    <!-- 确认卡片 -->
    <view wx:if="{{showConfirm && complaintData.isComplete}}" class="confirm-card" id="confirm-card">
      <view class="confirm-header">
        <text class="confirm-title">倾诉内容已整理好</text>
      </view>
      <view class="confirm-content" role="list">
        <view class="confirm-item" wx:if="{{complaintData.subject}}" role="listitem">
          <text class="confirm-label">对象：</text>
          <text class="confirm-value">{{complaintData.subject}}</text>
        </view>
        <view class="confirm-item" wx:if="{{complaintData.scene}}" role="listitem">
          <text class="confirm-label">场景：</text>
          <text class="confirm-value">{{complaintData.scene}}</text>
        </view>
        <view class="confirm-item" wx:if="{{complaintData.problem}}" role="listitem">
          <text class="confirm-label">问题：</text>
          <text class="confirm-value">{{complaintData.problem}}</text>
        </view>
        <view class="confirm-item" wx:if="{{complaintData.impact}}" role="listitem">
          <text class="confirm-label">影响：</text>
          <text class="confirm-value">{{complaintData.impact}}</text>
        </view>
        <view class="confirm-item" wx:if="{{complaintData.wish}}" role="listitem">
          <text class="confirm-label">期望：</text>
          <text class="confirm-value">{{complaintData.wish}}</text>
        </view>
      </view>
      <view class="confirm-actions">
        <button class="confirm-btn primary" bindtap="submitComplaint">确认提交</button>
        <button class="confirm-btn secondary" bindtap="continueChat">继续聊聊</button>
      </view>
    </view>

    <view style="height: 40px;"></view>
  </scroll-view>

  <!-- 底部输入和操作区 -->
  <view wx:if="{{!showWelcome}}" class="bottom-area">
    <!-- 文字输入（备选） -->
    <view class="text-input-section">
      <input 
        class="text-input"
        placeholder="或者在这里输入文字"
        value="{{inputValue}}"
        bindinput="onInputChange"
        bindconfirm="sendTextMessage"
        confirm-type="send"
      />
      <button class="send-btn {{inputValue.trim() ? 'active' : ''}}" bindtap="sendTextMessage" disabled="{{!inputValue.trim() || isLoading}}">
        发送
      </button>
    </view>

    <!-- 底部导航 -->
    <view class="bottom-nav">
      <button class="nav-btn" bindtap="resetChat">重新开始</button>
      <button class="nav-btn" bindtap="goList">吐槽广场</button>
    </view>
  </view>

  <!-- 状态提示 -->
  <view wx:if="{{statusText}}" class="status-toast {{statusType}}" aria-live="polite">
    <text>{{statusText}}</text>
  </view>
</view>
