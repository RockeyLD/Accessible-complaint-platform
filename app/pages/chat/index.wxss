/** 统一聊天页面样式 - 现代美化版（适配修复） */

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 50%, #f0f4f8 100%);
  box-sizing: border-box;
}

/* ========== 主题配色 ========== */
.theme-warm { 
  --primary: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%); 
  --primary-solid: #ff7e5f;
  --primary-light: rgba(255, 126, 95, 0.1);
  --bg: linear-gradient(135deg, #fff8f5 0%, #fff0eb 100%); 
}
.theme-blue { 
  --primary: linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%); 
  --primary-solid: #0ea5e9;
  --primary-light: rgba(14, 165, 233, 0.1);
  --bg: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); 
}
.theme-green { 
  --primary: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); 
  --primary-solid: #11998e;
  --primary-light: rgba(17, 153, 142, 0.1);
  --bg: linear-gradient(135deg, #f0fff4 0%, #e8fff0 100%); 
}
.theme-ocean {
  --primary: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  --primary-solid: #4facfe;
  --primary-light: rgba(79, 172, 254, 0.1);
  --bg: linear-gradient(135deg, #f0f9ff 0%, #e6f7ff 100%);
}

/* ========== 高对比度 ========== */
.high-contrast {
  --primary: linear-gradient(135deg, #000 0%, #333 100%) !important;
  --primary-solid: #000 !important;
  background: #fff !important;
}
.high-contrast .message-bubble {
  border: 2rpx solid #000 !important;
}
.high-contrast .user-message .message-bubble {
  background: #000 !important;
  color: #fff !important;
}
.high-contrast .ai-message .message-bubble {
  background: #fff !important;
  color: #000 !important;
}

/* ========== 大字体 ========== */
.large-font .message-text { font-size: 20px !important; }
.large-font .info-value { font-size: 16px !important; }
.large-font .text-area { font-size: 16px !important; }
.large-font .page-title { font-size: 18px !important; }

/* ========== 顶部工具栏 - 玻璃拟态 ========== */
.toolbar {
  display: grid;
  grid-template-columns: 140rpx 1fr 140rpx;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
  box-sizing: border-box;
  width: 100%;
}

.toolbar-left {
  display: flex;
  justify-content: flex-start;
}

.toolbar-right {
  display: flex;
  justify-content: flex-end;
}

.toolbar-center {
  text-align: center;
  padding: 0 12rpx;
  overflow: hidden;
}

.page-title {
  font-size: 30rpx;
  font-weight: 700;
  background: var(--primary);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.tool-btn {
  padding: 10rpx 16rpx;
  background: rgba(245, 247, 250, 0.8);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #666;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  font-weight: 500;
  white-space: nowrap;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tool-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tool-btn.active {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
  border: none;
}

/* ========== 设置栏 - 精致卡片 ========== */
.settings-bar {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  overflow-x: auto;
  flex-shrink: 0;
  box-sizing: border-box;
  width: 100%;
}

.settings-bar::-webkit-scrollbar {
  display: none;
}

.setting-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.setting-label {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
  white-space: nowrap;
}

.setting-value {
  padding: 6rpx 14rpx;
  background: var(--primary-light);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: var(--primary-solid);
  font-weight: 600;
  white-space: nowrap;
}

/* ========== 欢迎横幅 - 动态渐变 ========== */
.welcome-banner {
  margin: 24rpx;
  padding: 24rpx;
  background: var(--primary);
  border-radius: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.25);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.welcome-banner::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-20rpx, 20rpx); }
}

.welcome-icon {
  font-size: 44rpx;
  z-index: 1;
  flex-shrink: 0;
}

.welcome-text {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
  line-height: 1.6;
  z-index: 1;
  font-weight: 500;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

/* ========== 对话区域 ========== */
.chat-container {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
  animation: slideIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  max-width: 100%;
  box-sizing: border-box;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(30rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.user-message {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.message-content {
  max-width: 70%;
  min-width: 0;
  margin: 0 16rpx;
  flex: 0 1 auto;
}

.message-bubble {
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  word-wrap: break-word;
  word-break: break-word;
  overflow-wrap: break-word;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.user-message .message-bubble {
  background: var(--primary);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.ai-message .message-bubble {
  background: rgba(255, 255, 255, 0.95);
  color: #333;
  border-bottom-left-radius: 6rpx;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  display: block;
  font-weight: 450;
  word-wrap: break-word;
  word-break: break-word;
}

.message-meta {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #4caf50;
  font-weight: 500;
}

/* ========== 加载动画 - 精致 ========== */
.loading-bubble {
  background: rgba(240, 244, 248, 0.8) !important;
  padding: 24rpx 40rpx !important;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.loading-indicator {
  display: flex;
  gap: 10rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--primary-solid);
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* ========== 确认卡片 - 玻璃拟态 ========== */
.confirm-card {
  margin: 20rpx 0;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(102, 126, 234, 0.12);
  overflow: hidden;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  max-width: 100%;
  box-sizing: border-box;
}

.card-header {
  background: var(--primary);
  padding: 24rpx 28rpx;
  position: relative;
  overflow: hidden;
}

.card-header::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 120rpx;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1));
}

.card-title {
  display: block;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
  position: relative;
  z-index: 1;
}

.card-subtitle {
  color: rgba(255,255,255,0.85);
  font-size: 22rpx;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

.card-body {
  padding: 24rpx 28rpx;
}

.info-row {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.04);
}

.info-row:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 6rpx;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  font-weight: 500;
  word-wrap: break-word;
  word-break: break-word;
}

.card-actions {
  display: flex;
  padding: 24rpx 28rpx;
  gap: 16rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.04);
}

.action-btn {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  white-space: nowrap;
  min-width: 0;
}

.action-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.action-btn.primary {
  background: var(--primary);
  color: #fff;
}

.action-btn.secondary {
  background: rgba(245, 247, 250, 0.9);
  color: #666;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* ========== 输入区域 - 悬浮玻璃 ========== */
.input-section {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
  box-sizing: border-box;
  width: 100%;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 推荐输入 ========== */
.suggestion-area {
  padding: 16rpx 20rpx 12rpx;
  background: rgba(245, 247, 250, 0.6);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.suggestion-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.suggestion-title {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

.suggestion-refresh {
  font-size: 20rpx;
  color: var(--primary-solid);
  font-weight: 500;
  padding: 4rpx 12rpx;
  background: var(--primary-light);
  border-radius: 12rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.suggestion-chip {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  width: 100%;
  box-sizing: border-box;
}

.suggestion-chip:active {
  transform: scale(0.98);
  background: var(--primary-light);
  border-color: var(--primary-solid);
}

.suggestion-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  word-wrap: break-word;
  word-break: break-all;
  flex: 1;
}

/* 文字输入 */
.text-input-area {
  padding: 20rpx 24rpx;
}

.input-box {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  background: rgba(245, 247, 250, 0.9);
  border-radius: 40rpx;
  padding: 12rpx 12rpx 12rpx 24rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  width: 100%;
}

.text-area {
  flex: 1;
  min-height: 44rpx;
  max-height: 160rpx;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 12rpx 0;
  color: #333;
  font-weight: 450;
  box-sizing: border-box;
  width: 100%;
}

.send-btn {
  padding: 16rpx 28rpx;
  background: #e8e8e8;
  color: #bbb;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
  flex-shrink: 0;
  white-space: nowrap;
}

.send-btn.active {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.35);
}

.send-btn.active:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}

.input-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  font-weight: 500;
}

/* 语音输入 */
.voice-input-area {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  width: 100%;
}

.voice-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 12rpx 36rpx rgba(102, 126, 234, 0.4);
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.voice-btn::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s;
}

.voice-btn:active::before {
  opacity: 1;
}

.voice-btn.recording {
  background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
  box-shadow: 0 12rpx 36rpx rgba(244, 67, 54, 0.4);
  animation: pulse-record 1.5s infinite;
}

@keyframes pulse-record {
  0%, 100% { transform: scale(1); box-shadow: 0 12rpx 36rpx rgba(244, 67, 54, 0.4); }
  50% { transform: scale(1.05); box-shadow: 0 18rpx 48rpx rgba(244, 67, 54, 0.5); }
}

.voice-btn-icon {
  font-size: 56rpx;
  margin-bottom: 4rpx;
  position: relative;
  z-index: 1;
}

.voice-btn-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  position: relative;
  z-index: 1;
}

.voice-disabled-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  margin-bottom: 20rpx;
  background: rgba(245, 247, 250, 0.9);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  box-sizing: border-box;
  width: 100%;
}

.voice-disabled-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.voice-disabled-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
  font-weight: 600;
  text-align: center;
}

.voice-disabled-sub {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}

.fallback-input {
  display: flex;
  width: 100%;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.fallback-text {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 24rpx;
  background: rgba(245, 247, 250, 0.9);
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.fallback-send {
  padding: 0 32rpx;
  height: 80rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.25);
  flex-shrink: 0;
  white-space: nowrap;
}

.fallback-send[disabled] {
  background: #e0e0e0;
  color: #999;
  box-shadow: none;
}

/* ========== 底部操作 ========== */
.bottom-actions {
  display: flex;
  padding: 20rpx 24rpx 32rpx;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  width: 100%;
}

.bottom-btn {
  flex: 1;
  padding: 20rpx 16rpx;
  background: rgba(245, 247, 250, 0.9);
  color: #666;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  white-space: nowrap;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bottom-btn:active {
  transform: scale(0.96);
  background: rgba(235, 237, 240, 0.9);
}

/* ========== 状态栏 ========== */
.status-bar {
  position: fixed;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.85);
  z-index: 100;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  font-weight: 500;
  animation: fadeInUp 0.3s ease;
  white-space: nowrap;
  max-width: 80%;
  overflow: hidden;
  text-overflow: ellipsis;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translate(-50%, 20rpx); }
  to { opacity: 1; transform: translate(-50%, 0); }
}

.status-bar.success { background: rgba(76, 175, 80, 0.95); }
.status-bar.error { background: rgba(244, 67, 54, 0.95); }
.status-bar.warn { background: rgba(255, 152, 0, 0.95); }
