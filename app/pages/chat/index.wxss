/** 统一聊天页面样式 */

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

/* ========== 主题 ========== */
.theme-warm { --primary: #ff7e5f; --primary-light: #feb47b; --bg: #fff8f5; }
.theme-blue { --primary: #667eea; --primary-light: #764ba2; --bg: #f0f4ff; }
.theme-green { --primary: #11998e; --primary-light: #38ef7d; --bg: #f0fff4; }

/* ========== 高对比度 ========== */
.high-contrast {
  --primary: #000 !important;
  background: #fff !important;
}
.high-contrast .message-bubble {
  border: 2px solid #000 !important;
}
.high-contrast .user-message .message-bubble {
  background: #000 !important;
  color: #fff !important;
}
.high-contrast .ai-message .message-bubble {
  background: #fff !important;
  color: #000 !important;
}

/* ========== 大字体 ========== */
.large-font .message-text { font-size: 20px !important; }
.large-font .info-value { font-size: 18px !important; }
.large-font .text-area { font-size: 18px !important; }

/* ========== 顶部工具栏 ========== */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #fff;
  border-bottom: 1px solid #e8e8e8;
}

.toolbar-left, .toolbar-right {
  flex: 0 0 auto;
}

.toolbar-center {
  flex: 1;
  text-align: center;
}

.page-title {
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.tool-btn {
  padding: 8px 14px;
  background: #f5f7fa;
  border-radius: 16px;
  font-size: 14px;
  color: #666;
  border: none;
}

.tool-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* ========== 设置栏 ========== */
.settings-bar {
  display: flex;
  padding: 10px 16px;
  gap: 16px;
  background: #fff;
  border-bottom: 1px solid #f0f4f8;
  overflow-x: auto;
}

.setting-item {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

.setting-label {
  font-size: 13px;
  color: #666;
}

.setting-value {
  padding: 4px 10px;
  background: #f5f7fa;
  border-radius: 12px;
  font-size: 13px;
  color: #333;
}

.setting-switch {
  transform: scale(0.8);
}

/* ========== 欢迎横幅 ========== */
.welcome-banner {
  margin: 16px;
  padding: 20px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.welcome-icon {
  font-size: 32px;
}

.welcome-text {
  flex: 1;
  font-size: 14px;
  color: #fff;
  line-height: 1.7;
}

/* ========== 对话区域 ========== */
.chat-container {
  flex: 1;
  padding: 16px;
}

.message {
  display: flex;
  margin-bottom: 20px;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.user-message {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  flex-shrink: 0;
}

.message-content {
  max-width: 70%;
  margin: 0 12px;
}

.message-bubble {
  padding: 12px 16px;
  border-radius: 18px;
  word-wrap: break-word;
}

.user-message .message-bubble {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-bottom-right-radius: 4px;
}

.ai-message .message-bubble {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 4px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}

.message-text {
  font-size: 15px;
  line-height: 1.7;
  display: block;
}

.message-meta {
  margin-top: 6px;
  font-size: 12px;
  color: #4caf50;
}

.loading-bubble {
  background: #f0f4f8 !important;
  padding: 16px 24px !important;
}

.loading-indicator {
  display: flex;
  gap: 6px;
}

.loading-dot {
  width: 8px;
  height: 8px;
  background: #999;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* ========== 确认卡片 ========== */
.confirm-card {
  margin: 16px 0;
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  overflow: hidden;
  border: 2px solid #667eea;
}

.card-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 16px 20px;
}

.card-title {
  display: block;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 4px;
}

.card-subtitle {
  color: rgba(255,255,255,0.8);
  font-size: 13px;
}

.card-body {
  padding: 16px 20px;
}

.info-row {
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f4f8;
}

.info-row:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.info-label {
  display: block;
  font-size: 12px;
  color: #888;
  margin-bottom: 4px;
}

.info-value {
  font-size: 15px;
  color: #333;
  line-height: 1.6;
}

.card-actions {
  display: flex;
  padding: 16px 20px;
  gap: 12px;
  border-top: 1px solid #f0f4f8;
}

.action-btn {
  flex: 1;
  padding: 12px;
  border-radius: 24px;
  font-size: 15px;
  font-weight: 500;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.action-btn.secondary {
  background: #f5f7fa;
  color: #666;
}

/* ========== 输入区域 ========== */
.input-section {
  background: #fff;
  border-top: 1px solid #e8e8e8;
}

/* 文字输入 */
.text-input-area {
  padding: 12px 16px;
}

.input-box {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  background: #f5f7fa;
  border-radius: 24px;
  padding: 8px 8px 8px 16px;
}

.text-area {
  flex: 1;
  min-height: 24px;
  max-height: 100px;
  font-size: 15px;
  line-height: 1.5;
  padding: 8px 0;
}

.send-btn {
  padding: 10px 20px;
  background: #e0e0e0;
  color: #999;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
  border: none;
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.input-tip {
  display: block;
  text-align: center;
  font-size: 12px;
  color: #999;
  margin-top: 8px;
}

/* 语音输入 */
.voice-input-area {
  padding: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.voice-btn {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
  margin-bottom: 12px;
}

.voice-btn.recording {
  background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
  box-shadow: 0 4px 20px rgba(244, 67, 54, 0.4);
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.voice-btn-icon {
  font-size: 36px;
  margin-bottom: 4px;
}

.voice-btn-text {
  font-size: 14px;
  color: #fff;
}

.voice-disabled-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
  margin-bottom: 12px;
}

.voice-disabled-icon {
  font-size: 48px;
  margin-bottom: 12px;
  opacity: 0.5;
}

.voice-disabled-text {
  font-size: 16px;
  color: #666;
  margin-bottom: 6px;
}

.voice-disabled-sub {
  font-size: 13px;
  color: #999;
}

.fallback-input {
  display: flex;
  width: 100%;
  gap: 10px;
  padding-top: 12px;
  border-top: 1px solid #f0f4f8;
}

.fallback-text {
  flex: 1;
  height: 44px;
  padding: 0 16px;
  background: #f5f7fa;
  border-radius: 22px;
  font-size: 15px;
}

.fallback-send {
  padding: 0 20px;
  height: 44px;
  background: #667eea;
  color: #fff;
  border-radius: 22px;
  font-size: 14px;
  border: none;
}

.fallback-send[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* ========== 底部操作 ========== */
.bottom-actions {
  display: flex;
  padding: 12px 16px 24px;
  gap: 12px;
  background: #fff;
  border-top: 1px solid #f0f4f8;
}

.bottom-btn {
  flex: 1;
  padding: 12px;
  background: #f5f7fa;
  color: #666;
  border-radius: 20px;
  font-size: 14px;
  border: none;
}

/* ========== 状态栏 ========== */
.status-bar {
  position: fixed;
  bottom: 180px;
  left: 50%;
  transform: translateX(-50%);
  padding: 10px 20px;
  border-radius: 20px;
  font-size: 14px;
  color: #fff;
  background: rgba(0,0,0,0.8);
  z-index: 100;
}

.status-bar.success { background: #4caf50; }
.status-bar.error { background: #f44336; }
.status-bar.warn { background: #ff9800; }
