/** 统一入口页面 */

.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 24px;
  box-sizing: border-box;
}

.landing-header {
  text-align: center;
  margin-bottom: 48px;
}

.landing-title {
  display: block;
  font-size: 32px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12px;
  text-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.landing-subtitle {
  display: block;
  font-size: 16px;
  color: rgba(255,255,255,0.9);
}

.features {
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 48px;
  width: 100%;
  max-width: 320px;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  font-size: 24px;
}

.feature-text {
  font-size: 15px;
  color: #fff;
}

.start-section {
  width: 100%;
  max-width: 320px;
}

.start-hint {
  display: block;
  text-align: center;
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  margin-bottom: 16px;
}

.mode-buttons {
  display: flex;
  gap: 16px;
}

.mode-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 16px;
  background: #fff;
  border-radius: 16px;
  border: none;
  box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  transition: transform 0.2s;
}

.mode-btn:active {
  transform: scale(0.98);
}

.mode-icon {
  font-size: 40px;
  margin-bottom: 12px;
}

.mode-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.mode-desc {
  font-size: 12px;
  color: #888;
}

.text-mode {
  border-top: 4px solid #667eea;
}

.voice-mode {
  border-top: 4px solid #764ba2;
}
