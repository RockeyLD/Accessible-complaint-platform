<view class="page hearing-page theme-{{theme}} {{contrast ? 'contrast' : ''}}" style="font-size: {{fontSize}}%;">
  <!-- 顶部工具栏 -->
  <view class="toolbar">
    <view class="tool">
      <text class="tool-label">主题</text>
      <picker mode="selector" range="{{themeOptions}}" range-key="label" bindchange="onThemeChange">
        <view class="picker">{{currentThemeLabel}}</view>
      </picker>
    </view>
    <view class="tool">
      <text class="tool-label">字号</text>
      <picker mode="selector" range="{{fontSizeOptions}}" range-key="label" bindchange="onFontSizeChange">
        <view class="picker">{{currentFontSizeLabel}}</view>
      </picker>
    </view>
    <view class="tool">
      <button class="toggle-btn {{contrast ? 'active' : ''}}" bindtap="onToggleContrast">
        {{contrast ? "高对比" : "正常"}}
      </button>
    </view>
  </view>

  <!-- 欢迎语 -->
  <view class="welcome-panel" wx:if="{{showWelcome}}">
    <text class="welcome-title">🧏 听障友好 · AI倾诉助手</text>
    <text class="welcome-desc">我会陪你聊天，帮你把想说的话整理成清晰的倾诉。就像跟朋友聊天一样，自然地说出你的困扰。</text>
    <button class="start-btn" bindtap="startChat">开始倾诉</button>
  </view>

  <!-- 对话区域 -->
  <scroll-view wx:else class="chat-container" scroll-y scroll-into-view="{{scrollToMessage}}" enhanced show-scrollbar>
    <!-- AI初始欢迎 -->
    <view class="message ai-message">
      <view class="avatar">🤖</view>
      <view class="bubble">
        <text class="text">你好！我是你的无障碍倾诉助手。我在这里倾听你的困扰，帮你把想说的话整理得更清晰。你想聊聊最近遇到的什么问题吗？</text>
      </view>
    </view>

    <!-- 消息列表 -->
    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="message {{item.role === 'user' ? 'user-message' : 'ai-message'}} {{item.isError ? 'error-message' : ''}}">
      <view class="avatar">{{item.role === 'user' ? '🧏' : '🤖'}}</view>
      <view class="bubble">
        <text class="text" user-select>{{item.content}}</text>
        <view wx:if="{{item.parsed && item.parsed.isComplete}}" class="parsed-badge">✓ 已整理</view>
      </view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{isLoading}}" class="message ai-message loading-message">
      <view class="avatar">🤖</view>
      <view class="bubble loading">
        <view class="loading-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>

    <!-- 确认卡片 -->
    <view wx:if="{{showConfirm && complaintData.isComplete}}" class="confirm-card" id="confirm-card">
      <view class="confirm-header">
        <text class="confirm-title">📋 整理完成，确认提交</text>
      </view>
      <view class="confirm-content">
        <view class="confirm-item" wx:if="{{complaintData.subject}}">
          <text class="confirm-label">对象：</text>
          <text class="confirm-value">{{complaintData.subject}}</text>
        </view>
        <view class="confirm-item" wx:if="{{complaintData.scene}}">
          <text class="confirm-label">场景：</text>
          <text class="confirm-value">{{complaintData.scene}}</text>
        </view>
        <view class="confirm-item" wx:if="{{complaintData.problem}}">
          <text class="confirm-label">问题：</text>
          <text class="confirm-value">{{complaintData.problem}}</text>
        </view>
        <view class="confirm-item" wx:if="{{complaintData.impact}}">
          <text class="confirm-label">影响：</text>
          <text class="confirm-value">{{complaintData.impact}}</text>
        </view>
        <view class="confirm-item" wx:if="{{complaintData.wish}}">
          <text class="confirm-label">期望：</text>
          <text class="confirm-value">{{complaintData.wish}}</text>
        </view>
      </view>
      <view class="confirm-actions">
        <button class="confirm-btn primary" bindtap="submitComplaint">确认提交</button>
        <button class="confirm-btn secondary" bindtap="continueChat">继续聊聊</button>
      </view>
    </view>

    <view style="height: 20px;"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view wx:if="{{!showWelcome}}" class="input-area">
    <view class="input-wrap">
      <textarea 
        class="input-field" 
        placeholder="{{inputPlaceholder}}" 
        value="{{inputValue}}"
        bindinput="onInputChange"
        bindconfirm="sendMessage"
        maxlength="500"
        auto-height
        show-confirm-bar="{{false}}"
        adjust-position
      />
      <button class="send-btn {{inputValue.trim() ? 'active' : ''}}" bindtap="sendMessage" disabled="{{!inputValue.trim() || isLoading}}">
        发送
      </button>
    </view>
    <text class="input-hint">按回车或点击发送按钮</text>
  </view>

  <!-- 底部导航 -->
  <view wx:if="{{!showWelcome}}" class="bottom-nav">
    <button class="nav-btn" bindtap="resetChat">重新开始</button>
    <button class="nav-btn" bindtap="goList">吐槽广场</button>
  </view>

  <!-- 状态提示 -->
  <view wx:if="{{statusText}}" class="status-toast {{statusType}}">
    <text>{{statusText}}</text>
  </view>
</view>
